<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/public/index.css" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Indsend din kunst til iå.dk - få dine tegninger lavet til klistermærker og få halvdelen af prisen når de sælges."
    />
    <title>Indsend din kunst - iå.dk</title>
  </head>
  <body>
    <header>
      <h1 class="b">iå.dk</h1>
      <p>
        <a href="/">← tilbage</a>
      </p>
    </header>
    <div class="buy-page">
      <div class="buy-card">
        <div class="card-details">
          <h2 class="b">Indsend din kunst ✨</h2>
          <ul>
            <li>
              <span class="a">halvdelen</span> af prisen går direkte til dig når dit klistermærke sælges
            </li>
            <li>
              Vi laver dine tegninger til håndlavede klistermærker med <span class="b">glitrende</span> og <span class="a">metallisk</span> blæk
            </li>
            <li>Ingen AI - kun ægte kunst fra rigtige mennesker</li>
            <li>Dit data bliver behandlet sikkert og slettet efter brug</li>
          </ul>
          <form name="kunst-indsendelse" netlify>
            <p>
              <label
                >Dit navn:
                <input
                  required
                  placeholder="skriv her"
                  type="text"
                  name="navn"
              /></label>
            </p>
            <p>
              <label
                >Instagram eller email:
                <input
                  required
                  placeholder="@ditinstagram eller din@email.dk"
                  type="text"
                  name="kontakt"
              /></label>
            </p>
            <p>
              <label
                >Beskriv din kunst eller andre kommentarer:
                <input
                  placeholder="Fortæl os om din kunst..."
                  name="beskrivelse"
                ></input>
              </label>
            </p>
            <p>
              <button type="submit">
                indsend nu
                {% include "button.njk" %}
              </button>
            </p>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>
